@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Comprueba tu correo";
}

<h1>@ViewData["Title"]</h1>
<p>
    Si el correo indicado corresponde a una cuenta, recibirás un enlace para
    restablecer tu contraseña. Revisa tu bandeja de entrada.
</p>
<p class="mt-3">
    <a asp-page="./Login">&larr; Volver a acceder</a>
</p>
