@page
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Códigos de recuperación";
    ViewData["ActivePage"] = "TwoFactorAuthentication";
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>
<div class="alert alert-warning" role="alert">
    <p>
        <strong>Guarda estos códigos en un lugar seguro.</strong>
    </p>
    <p>
        Cada código de recuperación solo se puede usar una vez. Si pierdes tu dispositivo de autenticación,
        podrás usar uno de estos códigos para acceder.
    </p>
</div>
<div class="row">
    <div class="col-md-12">
        @if (Model.RecoveryCodes is not null)
        {
            <div class="recovery-codes">
                @for (var row = 0; row < Model.RecoveryCodes.Length; row += 2)
                {
                    <div>
                        <kbd>@Model.RecoveryCodes[row]</kbd>
                        @if (row + 1 < Model.RecoveryCodes.Length)
                        {
                            <kbd>@Model.RecoveryCodes[row + 1]</kbd>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
