@{
    // Marca activa la entrada correspondiente comparando con ViewData["ActivePage"],
    // que cada página de gestión fija. Sin depender de la clase interna
    // ManageNavPages de la Default UI. La 2FA la sigue sirviendo Identity desde su
    // ensamblado (en inglés, por ahora).
    var activePage = ViewData["ActivePage"] as string ?? "";
    string Active(string page) =>
        string.Equals(activePage, page, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    string Current(string page) =>
        string.Equals(activePage, page, StringComparison.OrdinalIgnoreCase) ? "page" : "false";
}
<ul class="nav nav-pills flex-column">
    <li class="nav-item"><a class="nav-link @Active("Index")" id="profile" asp-page="./Index" aria-current="@Current("Index")">Perfil</a></li>
    <li class="nav-item"><a class="nav-link @Active("ChangePassword")" id="change-password" asp-page="./ChangePassword" aria-current="@Current("ChangePassword")">Contraseña</a></li>
    <li class="nav-item"><a class="nav-link @Active("TwoFactorAuthentication")" id="two-factor" asp-page="./TwoFactorAuthentication" aria-current="@Current("TwoFactorAuthentication")">Autenticación en dos pasos</a></li>
</ul>
