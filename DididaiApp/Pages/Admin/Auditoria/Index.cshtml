@page
@using DididaiApp.Core.Models
@model DididaiApp.Pages.Admin.Auditoria.IndexModel
@{
    ViewData["Title"] = "Auditoría";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="mb-0">Registro de auditoría</h1>
</div>

<p class="text-muted">
    Traza de las acciones de gestión (altas, bajas, ediciones y resoluciones) realizadas en el back.
    Registro automático e inmutable: solo se consulta.
</p>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-sm-6 col-lg-3">
        <label class="form-label" for="Usuario">Usuario</label>
        <input class="form-control" type="text" id="Usuario" name="Usuario" value="@Model.Usuario" placeholder="correo del admin" />
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <label class="form-label" for="Accion">Acción</label>
        <select class="form-select" asp-for="Accion" asp-items="Html.GetEnumSelectList<TipoAccionAuditoria>()">
            <option value="">Todas</option>
        </select>
    </div>
    <div class="col-6 col-sm-3 col-lg-2">
        <label class="form-label" for="Desde">Desde</label>
        <input class="form-control" type="date" id="Desde" name="Desde" value="@(Model.Desde?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-6 col-sm-3 col-lg-2">
        <label class="form-label" for="Hasta">Hasta</label>
        <input class="form-control" type="date" id="Hasta" name="Hasta" value="@(Model.Hasta?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-12 col-lg-2 d-flex gap-2">
        <button type="submit" class="btn btn-primary flex-grow-1">Filtrar</button>
        <a class="btn btn-outline-secondary" asp-page="Index">Limpiar</a>
    </div>
</form>

@if (Model.Resultado.Total == 0)
{
    <p class="text-muted">No hay registros que coincidan con el criterio.</p>
}
else
{
    <p class="text-muted small">@Model.Resultado.Total registro(s). Página @Model.Resultado.Pagina de @Model.Resultado.TotalPaginas.</p>
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th class="text-nowrap">Fecha</th>
                    <th>Usuario</th>
                    <th>Acción</th>
                    <th class="d-none d-md-table-cell">Detalle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Resultado.Registros)
                {
                    var cambios = DididaiApp.Pages.Admin.Auditoria.IndexModel.FormatearCambios(r.Cambios);
                    <tr>
                        <td class="text-nowrap">@r.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-break">@r.Usuario</td>
                        <td>@Html.DisplayFor(_ => r.Accion)</td>
                        <td class="text-break">
                            @r.Detalle
                            @if (cambios.Count > 0)
                            {
                                <ul class="mb-0 mt-1 small text-muted">
                                    @foreach (var linea in cambios)
                                    {
                                        <li>@linea</li>
                                    }
                                </ul>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Resultado.TotalPaginas > 1)
    {
        <nav aria-label="Paginación de auditoría">
            <ul class="pagination">
                <li class="page-item @(Model.Resultado.Pagina <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-page="Index"
                       asp-route-Usuario="@Model.Usuario"
                       asp-route-Accion="@Model.Accion"
                       asp-route-Desde="@(Model.Desde?.ToString("yyyy-MM-dd"))"
                       asp-route-Hasta="@(Model.Hasta?.ToString("yyyy-MM-dd"))"
                       asp-route-Pagina="@(Model.Resultado.Pagina - 1)">Anterior</a>
                </li>
                <li class="page-item @(Model.Resultado.Pagina >= Model.Resultado.TotalPaginas ? "disabled" : "")">
                    <a class="page-link"
                       asp-page="Index"
                       asp-route-Usuario="@Model.Usuario"
                       asp-route-Accion="@Model.Accion"
                       asp-route-Desde="@(Model.Desde?.ToString("yyyy-MM-dd"))"
                       asp-route-Hasta="@(Model.Hasta?.ToString("yyyy-MM-dd"))"
                       asp-route-Pagina="@(Model.Resultado.Pagina + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
}
