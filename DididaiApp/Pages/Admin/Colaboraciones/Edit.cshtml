@page "{id:int}"
@model DididaiApp.Pages.Admin.Colaboraciones.EditModel
@{
    ViewData["Title"] = "Editar colaboración";
}

<h1 class="h3">Editar colaboración</h1>
<p class="text-muted">Tipo: <strong>@Model.TipoNombre</strong> <span class="small">(no se puede cambiar)</span></p>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Datos.Id" />

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <label asp-for="Datos.Importe" class="form-label"></label>
            <div class="input-group">
                <input asp-for="Datos.Importe" class="form-control" type="number" step="0.01" min="0.01" />
                <span class="input-group-text">€</span>
            </div>
            <span asp-validation-for="Datos.Importe" class="text-danger"></span>
        </div>

        @if (Model.EsCuota)
        {
            <div class="col-12 col-md-6">
                <label asp-for="Datos.Modalidad" class="form-label"></label>
                <select asp-for="Datos.Modalidad" class="form-select"
                        asp-items="Html.GetEnumSelectList<DididaiApp.Core.Models.ModalidadCuota>()"></select>
                <span asp-validation-for="Datos.Modalidad" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Datos.Iban" class="form-label"></label>
                <input asp-for="Datos.Iban" class="form-control" placeholder="ES91 2100 0418 4502 0005 1332" autocomplete="off" />
                <div class="form-text">Se comprueban país, longitud y dígitos de control.</div>
                <span asp-validation-for="Datos.Iban" class="text-danger"></span>
            </div>
        }
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Socios/Details" asp-route-id="@Model.SocioId">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
