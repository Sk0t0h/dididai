@page
@model DididaiApp.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Gestión";
}

<h1>Panel de gestión</h1>
<p class="lead">Zona privada. Solo accesible para usuarios con rol <strong>Admin</strong>.</p>

<div class="row g-3 mt-2">
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Socios</h5>
                <p class="card-text">Alta, consulta, edición y baja de socios colaboradores, con sus colaboraciones.</p>
                <a class="btn btn-primary" asp-page="/Admin/Socios/Index">Gestionar socios</a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Economía</h5>
                <p class="card-text">Ingresos por colaboraciones, gastos y balance de la ONG.</p>
                <a class="btn btn-primary" asp-page="/Admin/Economia/Index">Ver economía</a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">
                    Solicitudes
                    @if (Model.SolicitudesPendientes > 0)
                    {
                        <span class="badge text-bg-warning ms-1">@Model.SolicitudesPendientes pendientes</span>
                    }
                </h5>
                <p class="card-text">Solicitudes de colaboración recibidas desde el formulario público de la web.</p>
                <a class="btn btn-primary" asp-page="/Admin/Solicitudes/Index">Revisar solicitudes</a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Administradores</h5>
                <p class="card-text">Usuarios con acceso al back de gestión: alta y activación/desactivación.</p>
                <a class="btn btn-primary" asp-page="/Admin/Usuarios/Index">Gestionar administradores</a>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Auditoría</h5>
                <p class="card-text">Registro de las acciones de gestión (quién hizo qué y cuándo). Solo lectura.</p>
                <a class="btn btn-primary" asp-page="/Admin/Auditoria/Index">Ver auditoría</a>
            </div>
        </div>
    </div>
</div>
