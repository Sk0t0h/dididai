@page
@model DididaiApp.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Gestión";
}

<h1>Panel de gestión</h1>
<p class="lead">Zona privada. Solo accesible para usuarios con rol <strong>Admin</strong>.</p>

<div class="row g-3 mt-2">
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Socios</h5>
                <p class="card-text">Alta, consulta, edición y baja de socios colaboradores.</p>
                <a class="btn btn-primary" asp-page="/Admin/Socios/Index">Gestionar socios</a>
            </div>
        </div>
    </div>
</div>

<p class="text-muted mt-4">El módulo económico y los dashboards llegarán en próximas fases.</p>
