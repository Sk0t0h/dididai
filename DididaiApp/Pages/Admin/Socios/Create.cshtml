@page
@model DididaiApp.Pages.Admin.Socios.CreateModel
@{
    ViewData["Title"] = "Nuevo socio";
}

<h1>Nuevo socio</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <partial name="_CamposSocio" for="Socio" />

    @if (Model.IdReactivable is int reactId)
    {
        <div class="alert alert-warning mt-3">
            <a class="btn btn-warning btn-sm" asp-page="Details" asp-route-id="@reactId">
                Ir al socio de baja para reactivarlo
            </a>
        </div>
    }

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Dar de alta</button>
        <a class="btn btn-outline-secondary" asp-page="Index">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
