@page
@model DididaiApp.Pages.Admin.Socios.CreateModel
@{
    ViewData["Title"] = "Nuevo socio";
}

<h1>Nuevo socio</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @* Conserva el origen (solicitud) entre GET y POST para vincularla tras el alta. *@
    @if (Model.SolicitudId is int solId)
    {
        <input type="hidden" asp-for="SolicitudId" value="@solId" />
        <div class="alert alert-info">Alta a partir de una solicitud de colaboración. Al guardar, se vinculará y podrás crear su colaboración.</div>
    }

    <partial name="_CamposSocio" for="Socio" />

    @if (Model.IdReactivable is int reactId)
    {
        <div class="alert alert-warning mt-3">
            <a class="btn btn-warning btn-sm" asp-page="Details" asp-route-id="@reactId">
                Ir al socio de baja para reactivarlo
            </a>
        </div>
    }

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Dar de alta</button>
        <a class="btn btn-outline-secondary" asp-page="Index">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/validacion-socio.js" asp-append-version="true"></script>
}
