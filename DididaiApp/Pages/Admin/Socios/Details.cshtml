@page "{id:int}"
@model DididaiApp.Pages.Admin.Socios.DetailsModel
@using DididaiApp.Core.Models
@{
    ViewData["Title"] = "Ficha de socio";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="mb-0">@Model.Socio.Nombre @Model.Socio.Apellidos</h1>
    @if (Model.Socio.Activo)
    {
        <span class="badge text-bg-success">Activo</span>
    }
    else
    {
        <span class="badge text-bg-secondary">Baja</span>
    }
</div>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-success" role="alert">@mensaje</div>
}

<dl class="row">
    <dt class="col-sm-3">Documento</dt>
    <dd class="col-sm-9">@Model.Socio.Dni <span class="text-muted">(@Html.DisplayFor(m => m.Socio.TipoDocumento))</span></dd>
    <dt class="col-sm-3">Teléfono</dt><dd class="col-sm-9">@Model.Socio.Telefono</dd>
    <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Socio.Email</dd>
    <dt class="col-sm-3">Dirección</dt>
    <dd class="col-sm-9">@Model.Socio.Direccion, @Model.Socio.CodigoPostal @Model.Socio.Localidad (@Paises.Nombre(Model.Socio.PaisResidencia))</dd>
    <dt class="col-sm-3">Alta</dt><dd class="col-sm-9">@Model.Socio.FechaAlta.ToString("dd/MM/yyyy")</dd>
    @if (Model.Socio.FechaBaja is DateTime baja)
    {
        <dt class="col-sm-3">Baja</dt><dd class="col-sm-9">@baja.ToString("dd/MM/yyyy")</dd>
    }
    <dt class="col-sm-3">Privacidad</dt>
    <dd class="col-sm-9">@(Model.Socio.AceptaPrivacidad ? "Aceptada" : "No aceptada")</dd>
</dl>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4 mb-2">
    <h2 class="h4 mb-0">Colaboraciones</h2>
    <a class="btn btn-sm btn-primary" asp-page="/Admin/Colaboraciones/Create" asp-route-socioId="@Model.Socio.Id">
        Añadir colaboración
    </a>
</div>

@if (Model.Colaboraciones.Count == 0)
{
    <p class="text-muted">Este socio no tiene colaboraciones registradas.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th class="text-end">Importe</th>
                    <th>Detalle</th>
                    <th>Desde</th>
                    <th>Estado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Colaboraciones)
                {
                    <tr>
                        <td>
                            @(c switch
                            {
                                CuotaDomiciliada => "Cuota domiciliada",
                                AportacionUnica => "Aportación única",
                                Teaming => "Teaming",
                                _ => "Colaboración"
                            })
                        </td>
                        <td class="text-end">@c.Importe.ToString("N2") €</td>
                        <td>
                            @if (c is CuotaDomiciliada cuota)
                            {
                                <span>@cuota.Modalidad · @cuota.Iban</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@c.FechaInicio.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (c.Activa)
                            {
                                <span class="badge text-bg-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Finalizada @c.FechaFin?.ToString("dd/MM/yyyy")</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (c.Activa)
                            {
                                <form method="post" asp-page-handler="BajaColaboracion" asp-route-id="@c.Id" asp-route-socioId="@Model.Socio.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger js-confirm"
                                            data-confirm="¿Finalizar esta colaboración? Se conserva en el histórico pero deja de estar activa.">
                                        Dar de baja
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="d-flex flex-wrap gap-2 mt-4">
    <a class="btn btn-outline-secondary" asp-page="Index">Volver</a>
    <a class="btn btn-outline-primary" asp-page="Edit" asp-route-id="@Model.Socio.Id">Editar</a>

    @if (Model.Socio.Activo)
    {
        <form method="post" asp-page-handler="Baja" asp-route-id="@Model.Socio.Id" class="d-inline">
            <button type="submit" class="btn btn-outline-danger js-confirm"
                    data-confirm="¿Dar de baja a este socio? Se conservará su registro pero dejará de aparecer en el listado.">
                Dar de baja
            </button>
        </form>
    }
    else
    {
        <form method="post" asp-page-handler="Reactivar" asp-route-id="@Model.Socio.Id" class="d-inline">
            <button type="submit" class="btn btn-success">Reactivar</button>
        </form>
    }
</div>
