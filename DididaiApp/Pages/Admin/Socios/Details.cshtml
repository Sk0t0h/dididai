@page "{id:int}"
@model DididaiApp.Pages.Admin.Socios.DetailsModel
@using DididaiApp.Core.Models
@{
    ViewData["Title"] = "Ficha de socio";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="mb-0">@Model.Socio.Nombre @Model.Socio.Apellidos</h1>
    @if (Model.Socio.Activo)
    {
        <span class="badge text-bg-success">Activo</span>
    }
    else
    {
        <span class="badge text-bg-secondary">Baja</span>
    }
</div>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-success" role="alert">@mensaje</div>
}

<dl class="row">
    <dt class="col-sm-3">Documento</dt>
    <dd class="col-sm-9">@Model.Socio.Dni <span class="text-muted">(@Html.DisplayFor(m => m.Socio.TipoDocumento))</span></dd>
    <dt class="col-sm-3">Teléfono</dt><dd class="col-sm-9">@Model.Socio.Telefono</dd>
    <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Socio.Email</dd>
    <dt class="col-sm-3">Dirección</dt>
    <dd class="col-sm-9">
        @{
            var partes = new[] { Model.Socio.Direccion, Model.Socio.CodigoPostal, Model.Socio.Localidad }
                .Where(p => !string.IsNullOrWhiteSpace(p));
            var domicilio = string.Join(", ", partes);
        }
        @if (!string.IsNullOrWhiteSpace(domicilio))
        {
            @domicilio<text> </text>
        }
        <span class="text-muted">(@Paises.Nombre(Model.Socio.PaisResidencia))</span>
    </dd>
    <dt class="col-sm-3">Alta</dt><dd class="col-sm-9">@Model.Socio.FechaAlta.ToString("dd/MM/yyyy")</dd>
    @if (Model.Socio.FechaBaja is DateTime baja)
    {
        <dt class="col-sm-3">Baja</dt><dd class="col-sm-9">@baja.ToString("dd/MM/yyyy")</dd>
    }
    <dt class="col-sm-3">Privacidad</dt>
    <dd class="col-sm-9">@(Model.Socio.AceptaPrivacidad ? "Aceptada" : "No aceptada")</dd>
</dl>

<partial name="_TablaColaboraciones" model="new DididaiApp.Pages.Admin.Socios.TablaColaboracionesModel { SocioId = Model.Socio.Id, Colaboraciones = Model.Colaboraciones }" />

@* Solicitudes públicas vinculadas a este socio (trazabilidad: de dónde vino cada colaboración). *@
@if (Model.Solicitudes.Count > 0)
{
    <h2 class="h5 mt-4">Solicitudes vinculadas</h2>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Tipo</th>
                    <th>Estado</th>
                    <th>Colaboración</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sol in Model.Solicitudes)
                {
                    var badge = sol.Estado switch
                    {
                        EstadoSolicitud.Pendiente => "text-bg-secondary",
                        EstadoSolicitud.Gestionando => "text-bg-warning",
                        EstadoSolicitud.Aprobada => "text-bg-success",
                        EstadoSolicitud.Cancelada => "text-bg-danger",
                        _ => "text-bg-light"
                    };
                    <tr>
                        <td class="text-nowrap">@sol.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>@Html.DisplayFor(_ => sol.Tipo)</td>
                        <td><span class="badge @badge">@Html.DisplayFor(_ => sol.Estado)</span></td>
                        <td>@(sol.ColaboracionId is null ? "—" : "Creada")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Admin/Solicitudes/Details" asp-route-id="@sol.Id">Ver</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="d-flex flex-wrap gap-2 mt-4">
    <a class="btn btn-outline-secondary" asp-page="Index">Volver</a>
    <a class="btn btn-outline-primary" asp-page="Edit" asp-route-id="@Model.Socio.Id">Editar</a>

    @if (Model.Socio.Activo)
    {
        <form method="post" asp-page-handler="Baja" asp-route-id="@Model.Socio.Id" class="d-inline">
            <button type="submit" class="btn btn-outline-danger js-confirm"
                    data-confirm="¿Dar de baja a este socio? Se conservará su registro pero dejará de aparecer en el listado." data-confirm-ok="Dar de baja">
                Dar de baja
            </button>
        </form>
    }
    else
    {
        <form method="post" asp-page-handler="Reactivar" asp-route-id="@Model.Socio.Id" class="d-inline">
            <button type="submit" class="btn btn-success">Reactivar</button>
        </form>
    }
</div>
