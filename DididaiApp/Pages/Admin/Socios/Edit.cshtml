@page "{id:int}"
@model DididaiApp.Pages.Admin.Socios.EditModel
@{
    ViewData["Title"] = "Editar socio";
}

<h1>Editar socio</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Socio.Id" />
    <input type="hidden" asp-for="Socio.FechaAlta" />
    <input type="hidden" asp-for="Socio.FechaBaja" />

    <partial name="_CamposSocio" for="Socio" />

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        <a class="btn btn-outline-secondary" asp-page="Details" asp-route-id="@Model.Socio.Id">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/validacion-socio.js" asp-append-version="true"></script>
}
