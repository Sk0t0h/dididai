@page
@model DididaiApp.Pages.Admin.Socios.IndexModel
@{
    ViewData["Title"] = "Socios";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="mb-0">Socios</h1>
    <a class="btn btn-primary" asp-page="Create">Nuevo socio</a>
</div>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-success" role="alert">@mensaje</div>
}

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-sm-6 col-md-5">
        <label for="Busqueda" class="form-label">Buscar</label>
        <input type="text" class="form-control" id="Busqueda" name="Busqueda"
               value="@Model.Busqueda" placeholder="Nombre, apellidos, DNI o email" />
    </div>
    <div class="col-auto">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="IncluirBajas" name="IncluirBajas"
                   value="true" @(Model.IncluirBajas ? "checked" : "") />
            <label class="form-check-label" for="IncluirBajas">Incluir bajas</label>
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filtrar</button>
    </div>
</form>

@if (Model.Socios.Count == 0)
{
    <p class="text-muted">No hay socios que coincidan con el criterio.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Apellidos, Nombre</th>
                    <th>DNI</th>
                    <th class="d-none d-md-table-cell">Email</th>
                    <th class="d-none d-md-table-cell">Localidad</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Socios)
                {
                    <tr>
                        <td>@s.Apellidos, @s.Nombre</td>
                        <td>@s.Dni</td>
                        <td class="d-none d-md-table-cell">@s.Email</td>
                        <td class="d-none d-md-table-cell">@s.Localidad</td>
                        <td>
                            @if (s.Activo)
                            {
                                <span class="badge text-bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Baja</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="Details" asp-route-id="@s.Id">Ver</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-id="@s.Id">Editar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
