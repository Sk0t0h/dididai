@model DididaiApp.Core.Models.Socio
@using DididaiApp.Core.Models

<div class="row g-3">
    <div class="col-12 col-md-6">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-6">
        <label asp-for="Apellidos" class="form-label"></label>
        <input asp-for="Apellidos" class="form-control" />
        <span asp-validation-for="Apellidos" class="text-danger"></span>
    </div>

    <div class="col-12 col-md-4">
        <label asp-for="TipoDocumento" class="form-label"></label>
        <select asp-for="TipoDocumento" class="form-select" data-tipo-doc
                asp-items="Html.GetEnumSelectList<TipoDocumento>()">
        </select>
        <span asp-validation-for="TipoDocumento" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-8">
        <label asp-for="Dni" class="form-label"></label>
        <input asp-for="Dni" class="form-control" data-documento aria-describedby="dniAyuda" />
        <div id="dniAyuda" class="form-text" data-dni-ayuda>
            Para DNI/NIE se comprueba la letra de control.
        </div>
        <span asp-validation-for="Dni" class="text-danger"></span>
    </div>

    <div class="col-12 col-md-6">
        <label class="form-label" for="Telefono_Numero">Teléfono</label>
        <div class="input-group">
            <label class="visually-hidden" for="Telefono_Prefijo">Prefijo internacional</label>
            <select id="Telefono_Prefijo" class="form-select flex-grow-0 w-auto" data-tel-prefijo>
                @foreach (var p in PrefijosTelefonicos.Todos)
                {
                    <option value="@p.Codigo" data-pais="@p.PaisCodigo">@p.Nombre</option>
                }
            </select>
            <input id="Telefono_Numero" type="tel" inputmode="numeric" class="form-control"
                   placeholder="612345678" autocomplete="off" data-tel-numero aria-describedby="telAyuda" />
        </div>
        <div id="telAyuda" class="form-text">Elige el prefijo del país del número y escribe el resto.</div>
        @* El valor que se guarda y valida (E.164) lo compone el JS a partir de prefijo + número. *@
        <input asp-for="Telefono" type="hidden" data-tel-completo />
        <span asp-validation-for="Telefono" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Direccion" class="form-label"></label>
        <input asp-for="Direccion" class="form-control" />
        <span asp-validation-for="Direccion" class="text-danger"></span>
    </div>
    <div class="col-6 col-md-3">
        <label asp-for="CodigoPostal" class="form-label"></label>
        <input asp-for="CodigoPostal" class="form-control" />
        <span asp-validation-for="CodigoPostal" class="text-danger"></span>
    </div>
    <div class="col-6 col-md-4">
        <label asp-for="Localidad" class="form-label"></label>
        <input asp-for="Localidad" class="form-control" />
        <span asp-validation-for="Localidad" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-5">
        <label asp-for="PaisResidencia" class="form-label"></label>
        <input type="search" class="form-control mb-1" placeholder="Buscar país…"
               data-pais-buscador aria-label="Buscar país de residencia" autocomplete="off" />
        <select asp-for="PaisResidencia" class="form-select" data-pais-select
                asp-items="@(new SelectList(Paises.Todos, nameof(Paises.Pais.Codigo), nameof(Paises.Pais.Nombre), Model.PaisResidencia))">
        </select>
        <span asp-validation-for="PaisResidencia" class="text-danger"></span>
    </div>

    <div class="col-12">
        <div class="form-check">
            <input asp-for="AceptaPrivacidad" class="form-check-input" />
            <label asp-for="AceptaPrivacidad" class="form-check-label">
                El socio acepta la política de privacidad (RGPD)
            </label>
        </div>
        <span asp-validation-for="AceptaPrivacidad" class="text-danger"></span>
    </div>
</div>
