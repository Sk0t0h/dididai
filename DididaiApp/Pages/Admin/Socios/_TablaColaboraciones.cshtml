@using DididaiApp.Core.Models
@model DididaiApp.Pages.Admin.Socios.TablaColaboracionesModel
@*
    Tabla de colaboraciones de un socio (ver / crear / editar / dar de baja).
    Reutilizada por la ficha (Details) y por la edición (Edit) del socio, para
    tener la gestión a mano desde ambas. El alta y la edición llevan a las páginas
    dedicadas de Colaboraciones; la baja es un POST al handler BajaColaboracion de
    la página que aloja este partial (existe en Details y en Edit).
*@

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4 mb-2">
    <h2 class="h4 mb-0">Colaboraciones</h2>
    <a class="btn btn-sm btn-primary" asp-page="/Admin/Colaboraciones/Create" asp-route-socioId="@Model.SocioId">
        Añadir colaboración
    </a>
</div>

@if (Model.Colaboraciones.Count == 0)
{
    <p class="text-muted">Este socio no tiene colaboraciones registradas.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th class="text-end">Importe</th>
                    <th>Detalle</th>
                    <th>Desde</th>
                    <th>Estado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Colaboraciones)
                {
                    <tr>
                        <td>
                            @(c switch
                            {
                                CuotaDomiciliada => "Cuota domiciliada",
                                AportacionUnica => "Aportación única",
                                Teaming => "Teaming",
                                _ => "Colaboración"
                            })
                        </td>
                        <td class="text-end">@c.Importe.ToString("N2") €</td>
                        <td>
                            @if (c is CuotaDomiciliada cuota)
                            {
                                <span>@cuota.Modalidad · @cuota.Iban</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@c.FechaInicio.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (c.Activa)
                            {
                                <span class="badge text-bg-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Finalizada @c.FechaFin?.ToString("dd/MM/yyyy")</span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Colaboraciones/Edit" asp-route-id="@c.Id">Editar</a>
                            @if (c.Activa)
                            {
                                <form method="post" asp-page-handler="BajaColaboracion" asp-route-id="@c.Id" asp-route-socioId="@Model.SocioId" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger js-confirm"
                                            data-confirm="¿Finalizar esta colaboración? Se conserva en el histórico pero deja de estar activa." data-confirm-ok="Finalizar">
                                        Dar de baja
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
