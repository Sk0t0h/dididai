@page "{id:int}"
@using DididaiApp.Core.Models
@model DididaiApp.Pages.Admin.Solicitudes.DetailsModel
@{
    ViewData["Title"] = "Solicitud de colaboración";
    var s = Model.Solicitud;
    var badge = s.Estado switch
    {
        EstadoSolicitud.Pendiente => "text-bg-secondary",
        EstadoSolicitud.Gestionando => "text-bg-warning",
        EstadoSolicitud.Aprobada => "text-bg-success",
        EstadoSolicitud.Cancelada => "text-bg-danger",
        _ => "text-bg-light"
    };
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="mb-0">Solicitud de colaboración</h1>
    <a class="btn btn-outline-secondary" asp-page="Index">Volver al listado</a>
</div>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-info" role="alert">@mensaje</div>
}

<div class="row g-4">
    <div class="col-12 col-lg-7">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h5 class="card-title mb-0">@s.Nombre @s.Apellidos</h5>
                    <span class="badge @badge">@Html.DisplayFor(m => m.Solicitud.Estado)</span>
                </div>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8"><a href="mailto:@s.Email">@s.Email</a></dd>

                    <dt class="col-sm-4">Teléfono</dt>
                    <dd class="col-sm-8">@s.Telefono</dd>

                    <dt class="col-sm-4">Tipo</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(m => m.Solicitud.Tipo)</dd>

                    @if (s.Importe is decimal importe)
                    {
                        <dt class="col-sm-4">Importe indicado</dt>
                        <dd class="col-sm-8">@importe.ToString("N2") €</dd>
                    }

                    @if (s.Periodicidad is ModalidadCuota periodicidad)
                    {
                        <dt class="col-sm-4">Periodicidad</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(m => m.Solicitud.Periodicidad)</dd>
                    }

                    <dt class="col-sm-4">Recibida</dt>
                    <dd class="col-sm-8">@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

                    @if (s.FechaRevision is DateTime revision)
                    {
                        <dt class="col-sm-4">Revisada</dt>
                        <dd class="col-sm-8">@revision.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(s.NotaRevision))
                    {
                        <dt class="col-sm-4">Nota</dt>
                        <dd class="col-sm-8">@s.NotaRevision</dd>
                    }
                </dl>
            </div>
        </div>

        @* --- Historial de gestión (columna izquierda, bajo los datos) --- *@
        <div class="card mt-4">
            <div class="card-body">
                <h5 class="card-title">Gestión</h5>
                <p class="card-text text-muted small">Registra cada contacto o seguimiento. La primera acción pasa la solicitud a «Gestionando». Queda constancia de quién y cuándo.</p>

                <form method="post" class="mb-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-12 col-sm-4">
                            <label asp-for="AccionTipo" class="form-label">Tipo</label>
                            <select asp-for="AccionTipo" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<TipoAccionSolicitud>()"></select>
                        </div>
                        <div class="col-12 col-sm-8">
                            <label asp-for="AccionNota" class="form-label">Nota</label>
                            <textarea asp-for="AccionNota" class="form-control" rows="2" maxlength="1000" placeholder="Qué se hizo / habló, seguimiento…"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary mt-2" asp-page-handler="Accion" asp-route-id="@s.Id">Registrar acción</button>
                </form>

                @if (s.Acciones.Count == 0)
                {
                    <p class="text-muted small mb-0">Sin acciones registradas.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var a in s.Acciones.OrderByDescending(x => x.Fecha))
                        {
                            <li class="border-top py-2">
                                <div class="d-flex justify-content-between gap-2">
                                    <span class="fw-semibold">@Html.DisplayFor(_ => a.Tipo)</span>
                                    <span class="text-muted small text-nowrap">@a.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <div>@a.Nota</div>
                                <div class="text-muted small">@a.Usuario</div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        @* "Revisar" está disponible mientras la solicitud NO esté resuelta: tanto Pendiente
           como Gestionando (aprobar/cancelar es justo el paso siguiente a gestionarla). *@
        @if (s.Estado is EstadoSolicitud.Pendiente or EstadoSolicitud.Gestionando)
        {
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Revisar</h5>
                    <p class="card-text text-muted small">Aprobar o cancelar deja constancia de la resolución. Aprobar no da de alta al socio automáticamente: usa el bloque «Socio» para vincularlo o crearlo.</p>
                    <form method="post">
                        <div class="mb-3">
                            <label for="Nota" class="form-label">Nota (opcional)</label>
                            <textarea class="form-control" id="Nota" name="Nota" rows="2" maxlength="500" placeholder="Motivo del rechazo, seguimiento…"></textarea>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-success"
                                    asp-page-handler="Resolver" asp-route-id="@s.Id" asp-route-estado="@EstadoSolicitud.Aprobada">
                                Aprobar
                            </button>
                            <button type="submit" class="btn btn-outline-danger js-confirm" data-confirm="¿Cancelar esta solicitud?" data-confirm-ok="Cancelar solicitud"
                                    asp-page-handler="Resolver" asp-route-id="@s.Id" asp-route-estado="@EstadoSolicitud.Cancelada">
                                Cancelar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }

        @if (s.Estado != EstadoSolicitud.Cancelada)
        {
            <div class="card mt-3">
                <div class="card-body">
                    <h5 class="card-title">Socio</h5>

                    @if (Model.SocioVinculado is Socio vinc)
                    {
                        <p class="card-text small mb-2">Esta solicitud está vinculada al socio:</p>
                        <p class="mb-2"><strong>@vinc.Apellidos, @vinc.Nombre</strong> <span class="text-muted">· @vinc.Email</span></p>
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Socios/Details" asp-route-id="@vinc.Id">Ver ficha del socio</a>

                        @* Crear la colaboración de esta solicitud para el socio vinculado. *@
                        @if (s.ColaboracionId is not null)
                        {
                            <p class="text-success small mt-3 mb-0">✓ Colaboración creada y asociada al socio.</p>
                        }
                        else if (s.Tipo == TipoColaboracionSolicitada.Microdonacion)
                        {
                            <p class="text-muted small mt-3 mb-0">La microdonación se gestiona en Teaming; no genera colaboración aquí.</p>
                        }
                        else
                        {
                            <hr />
                            <h6>Crear colaboración</h6>
                            <p class="card-text text-muted small">Confirma los datos para registrar la colaboración de este socio a partir de la solicitud.</p>
                            <form method="post">
                                <div class="mb-2">
                                    <label asp-for="ColabImporte" class="form-label">Importe (€)</label>
                                    <input asp-for="ColabImporte" type="number" min="0.01" step="0.01" class="form-control form-control-sm" value="@(s.Importe ?? 0m)" />
                                </div>
                                @if (s.Tipo == TipoColaboracionSolicitada.Socio)
                                {
                                    <div class="mb-2">
                                        <label asp-for="ColabModalidad" class="form-label">Periodicidad</label>
                                        <select asp-for="ColabModalidad" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<ModalidadCuota>()"></select>
                                    </div>
                                    <div class="mb-2">
                                        <label asp-for="ColabIban" class="form-label">IBAN</label>
                                        <input asp-for="ColabIban" class="form-control form-control-sm" placeholder="ES91 2100 0418 4502 0005 1332" autocomplete="off" />
                                    </div>
                                }
                                <button type="submit" class="btn btn-sm btn-primary" asp-page-handler="CrearColaboracion" asp-route-id="@s.Id">Crear colaboración</button>
                            </form>
                        }
                    }
                    else
                    {
                        @if (Model.PosiblesCoincidencias.Count > 0)
                        {
                            <p class="card-text text-muted small">Hay socios que coinciden por email o teléfono. Si la persona ya colabora, vincúlala; si no, crea un socio nuevo.</p>
                            <ul class="list-unstyled mb-3">
                                @foreach (var c in Model.PosiblesCoincidencias)
                                {
                                    <li class="border-top py-2 d-flex justify-content-between align-items-center gap-2">
                                        <span>
                                            <strong>@c.Apellidos, @c.Nombre</strong>
                                            <span class="text-muted small d-block">@c.Email · @c.Telefono</span>
                                        </span>
                                        <form method="post" class="mb-0">
                                            <button type="submit" class="btn btn-sm btn-outline-primary text-nowrap"
                                                    asp-page-handler="Vincular" asp-route-id="@s.Id" asp-route-socioId="@c.Id">
                                                Es este socio
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="card-text text-muted small">No hay socios que coincidan por email o teléfono. Crea un socio nuevo con estos datos.</p>
                        }

                        <a class="btn btn-primary"
                           asp-page="/Admin/Socios/Create"
                           asp-route-solicitudId="@s.Id">
                            Crear socio con estos datos
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>
