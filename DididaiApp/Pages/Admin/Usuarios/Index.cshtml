@page
@model DididaiApp.Pages.Admin.Usuarios.IndexModel
@{
    ViewData["Title"] = "Administradores";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="mb-0">Administradores</h1>
    <a class="btn btn-primary" asp-page="Create">Nuevo administrador</a>
</div>

@if (TempData["Mensaje"] is string mensaje)
{
    <div class="alert alert-success" role="alert">@mensaje</div>
}

<p class="text-muted">Usuarios con acceso al back de gestión (rol <strong>Admin</strong>). Las altas se hacen desde aquí; el registro público está deshabilitado.</p>

@if (Model.Admins.Count == 0)
{
    <p class="text-muted">No hay administradores.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Admins)
                {
                    var esUnoMismo = string.Equals(a.Email, Model.EmailActual, StringComparison.OrdinalIgnoreCase);
                    <tr>
                        <td>
                            @a.Email
                            @if (a.EsSuperAdmin)
                            {
                                <span class="badge text-bg-primary ms-1">Principal</span>
                            }
                        </td>
                        <td>
                            @if (a.Activo)
                            {
                                <span class="badge text-bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Desactivado</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            @* El superadmin es intocable; nadie puede desactivarse a sí mismo. *@
                            @if (a.EsSuperAdmin || esUnoMismo)
                            {
                                <span class="text-muted small">—</span>
                            }
                            else if (a.Activo)
                            {
                                <form method="post" asp-page-handler="Desactivar" asp-route-id="@a.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger js-confirm"
                                            data-confirm="¿Desactivar a @a.Email? No podrá iniciar sesión hasta que se reactive." data-confirm-ok="Desactivar">
                                        Desactivar
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Reactivar" asp-route-id="@a.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-success">Reactivar</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
