@using System.Globalization
@inject IViewLocalizer Localizer
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DididaiApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DididaiApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
      @if (User.Identity?.IsAuthenticated == true)
      {
        @* Cabecera de GESTIÓN: mismo lenguaje visual que el front (logo + claro/crema),
           sin selector de idioma (el back es solo español). Logo y usuario a la izquierda;
           secciones a la derecha. *@
        <nav class="admin-header">
            <div class="container admin-bar">
                <a class="admin-brand" asp-area="" asp-page="/Index" aria-label="DIDIDAI inicio">
                    <img src="~/images/brand/logo.png" alt="Logo de DIDIDAI" />
                </a>
                <a class="admin-user" asp-area="Identity" asp-page="/Account/Manage/Index" title="Gestionar mi cuenta">@User.Identity?.Name</a>
                <nav class="admin-nav" aria-label="Gestión">
                    <a asp-area="" asp-page="/Admin/Index">Admin</a>
                    <a asp-area="" asp-page="/Admin/Socios/Index">Socios</a>
                    <a asp-area="" asp-page="/Admin/Economia/Index">Economía</a>
                    <a asp-area="" asp-page="/Admin/Solicitudes/Index">Solicitudes</a>
                    <a asp-area="" asp-page="/Admin/Usuarios/Index">Administradores</a>
                    <a asp-area="" asp-page="/Admin/Auditoria/Index">Auditoría</a>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" method="post" class="d-inline">
                        <button type="submit" class="admin-salir">Salir</button>
                    </form>
                </nav>
            </div>
        </nav>
      }
      else
      {
        @* Sin sesión (páginas de acceso/gestión que usan este layout: login, recuperación
           de contraseña, Privacy, Error): cabecera de marca minimalista, solo el logo
           enlazando al inicio. Mismo look crema que la cabecera con sesión → todo el back
           habla el mismo idioma visual. No se mete navegación de marketing ni selector de
           idioma en una pantalla de acceso (el selector vive en el _PublicLayout del front). *@
        <nav class="admin-header">
            <div class="container admin-bar">
                <a class="admin-brand" asp-area="" asp-page="/Index" aria-label="DIDIDAI inicio">
                    <img src="~/images/brand/logo.png" alt="Logo de DIDIDAI" />
                </a>
            </div>
        </nav>
      }
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - DIDIDAI - <a asp-area="" asp-page="/Privacy">@Localizer["Footer_Privacy"]</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
